{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "NEXT_PUBLIC_API_URL": "https://kulobalhealth-backend-qlhm.onrender.com"
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
